# ── Application ───────────────────────────────────────────────────────────────

# TMDb API read access token (required) — https://www.themoviedb.org/settings/api
TMDB_TOKEN=

# Upstash Redis — global rate limiting and response cache (required in production)
# Create a free database at https://console.upstash.com/redis
# Open the database → "REST API" tab → copy UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Canonical site URL (used for metadata / Open Graph)
NEXT_PUBLIC_SITE_URL=https://nextmovies.wyco-dev.com

# Set to "true" ONLY when running behind the bundled nginx reverse proxy
# (nginx overwrites X-Real-IP from Cloudflare's CF-Connecting-IP).
# Never enable when the app port is directly reachable — the header becomes spoofable.
TRUSTED_PROXY=true

# ── Deployment (used by docker-compose / nginx, not the app) ─────────────────

# Public domain served by nginx
DOMAIN=nextmovies.wyco-dev.com

# Docker image to run (CI pushes here; deploy pulls it)
DOCKER_IMAGE=ghcr.io/wyco68/movieweb:latest
