# ── Cloudflare Pages environment variables ────────────────────────────────────
#
# In production these are set in the Cloudflare Pages dashboard
# (Settings → Environment variables), NOT committed. Locally, copy this file to
# `.env` and run the full stack with `npm run preview` (wrangler pages dev).

# TMDb API read access token (REQUIRED) — https://www.themoviedb.org/settings/api
# Used only inside the /api/tmdb Pages Function; it never reaches the browser.
TMDB_TOKEN=

# Upstash Redis (recommended) — backs global rate limiting, IP bans and a short
# TMDB list-response cache inside the /api/tmdb function. This is a free external
# REST service, NOT Cloudflare Workers KV. If left unset the function still works
# and falls back to a strict per-isolate in-memory rate limiter.
# Create a free database at https://console.upstash.com/redis → "REST API" tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: "true" enables Upstash rate-limit analytics (extra Redis commands).
UPSTASH_RATELIMIT_ANALYTICS=

# Canonical site URL (used for metadata / Open Graph). Public — inlined at build
# time, so it must be present in the build environment.
NEXT_PUBLIC_SITE_URL=https://example.com
