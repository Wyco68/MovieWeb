# ── Application ───────────────────────────────────────────────────────────────

# TMDb API read access token (required) — https://www.themoviedb.org/settings/api
# Server-side only. On Cloudflare, set as a Worker secret (see docs/CLOUDFLARE.md).
TMDB_TOKEN=

# Upstash Redis — global rate limiting, IP bans, response cache (required in production)
# Create a free database at https://console.upstash.com/redis
# Open the database → "REST API" tab → copy UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Canonical site URL (used for metadata / Open Graph). Public — inlined at build time.
NEXT_PUBLIC_SITE_URL=https://nextmovies.wyco-dev.com

# Optional: "true" enables Upstash rate-limit analytics (extra Redis commands). Off by default.
UPSTASH_RATELIMIT_ANALYTICS=

# Legacy escape hatch: trust x-real-ip. NOT needed on Cloudflare — the app reads the
# unspoofable CF-Connecting-IP header automatically. Leave unset.
TRUSTED_PROXY=
